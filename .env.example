# Anthropic API key (optional — if not set, uses Claude Code subscription auth via `claude login`)
# ANTHROPIC_API_KEY=

# Optional: override default data directory (~/.talentclaw)
# TALENTCLAW_DIR=

# Optional: override Claude model (default: claude-sonnet-4-20250514)
# TALENTCLAW_MODEL=

# Optional: Greenhouse Job Board API key for direct application submission
# GREENHOUSE_API_KEY=

# Optional: Ashby API key (needs candidatesWrite + jobsRead permissions)
# ASHBY_API_KEY=
